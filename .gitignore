# ─── Generated Assets (re-jenere ak: node generate-assets.js) ────
# Kòmante liy sa yo si ou vle commit icons yo dirèkteman
assets/icons/icon_*.png
assets/icons/icon.ico
assets/icons/icon.icns
assets/icons/manifest.json
# Gade icon.svg ak icon.png (512px) — yo piti epi itil pou GitHub
!assets/icons/icon.svg
!assets/icons/icon.png

